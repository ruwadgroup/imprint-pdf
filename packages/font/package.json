{
  "name": "@imprint/font",
  "version": "0.1.0",
  "description": "Font loaders for imprint — Google Fonts, Bunny Fonts, Fontsource, and local files. Returns FontDeclaration[] for renderToBuffer.",
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint.git",
    "directory": "packages/font"
  },
  "homepage": "https://github.com/tamimbinhakim/imprint/tree/main/packages/font#readme",
  "bugs": "https://github.com/tamimbinhakim/imprint/issues",
  "keywords": ["pdf", "fonts", "google-fonts", "bunny-fonts", "fontsource", "imprint"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./hyphen": {
      "types": "./dist/hyphen.d.ts",
      "import": {
        "types": "./dist/hyphen.d.ts",
        "default": "./dist/hyphen.js"
      },
      "require": {
        "types": "./dist/hyphen.d.cts",
        "default": "./dist/hyphen.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "data", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "codegen": "tsx scripts/codegen-hyphen.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@imprint/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
