{
  "name": "@imprint-pdf/fonts",
  "version": "1.0.0-alpha.7",
  "description": "Ergonomic font declarations for imprint-pdf — Google Fonts via Fontsource, zero-config.",
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint-pdf.git",
    "directory": "packages/fonts"
  },
  "homepage": "https://github.com/tamimbinhakim/imprint-pdf/tree/main/packages/fonts#readme",
  "bugs": "https://github.com/tamimbinhakim/imprint-pdf/issues",
  "keywords": [
    "pdf",
    "fonts",
    "google-fonts",
    "fontsource",
    "imprint"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./google": {
      "types": "./dist/google.d.ts",
      "import": {
        "types": "./dist/google.d.ts",
        "default": "./dist/google.js"
      },
      "require": {
        "types": "./dist/google.d.cts",
        "default": "./dist/google.cjs"
      }
    },
    "./hyphen": {
      "types": "./dist/hyphen.d.ts",
      "import": {
        "types": "./dist/hyphen.d.ts",
        "default": "./dist/hyphen.js"
      },
      "require": {
        "types": "./dist/hyphen.d.cts",
        "default": "./dist/hyphen.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "data",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage",
    "codegen": "tsx scripts/codegen-hyphen.ts",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@imprint-pdf/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
