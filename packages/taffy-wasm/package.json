{
  "name": "@imprint-pdf/taffy-wasm",
  "version": "1.0.0-alpha",
  "description": "Taffy CSS layout engine (Rust→WASM) for imprint-pdf",
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint-pdf.git",
    "directory": "packages/taffy-wasm"
  },
  "homepage": "https://github.com/tamimbinhakim/imprint-pdf/tree/main/packages/taffy-wasm#readme",
  "bugs": "https://github.com/tamimbinhakim/imprint-pdf/issues",
  "type": "module",
  "main": "./pkg/imprint_taffy.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./pkg/imprint_taffy.js"
    }
  },
  "files": [
    "pkg",
    "src/index.ts"
  ],
  "scripts": {
    "build": "wasm-pack build --target web --out-dir pkg",
    "build:node": "wasm-pack build --target nodejs --out-dir pkg-node",
    "clean": "rm -rf pkg pkg-node target"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
