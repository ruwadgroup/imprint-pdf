{
  "name": "@imprint-pdf/tailwind",
  "private": true,
  "version": "1.0.0-alpha.3",
  "description": "Vite, Webpack, and Bun plugins for compile-time Tailwind v4 extraction, plus the runtime Oxide WASM fallback.",
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint-pdf.git",
    "directory": "packages/tailwind"
  },
  "homepage": "https://github.com/tamimbinhakim/imprint-pdf/tree/main/packages/tailwind#readme",
  "bugs": "https://github.com/tamimbinhakim/imprint-pdf/issues",
  "keywords": [
    "tailwind",
    "pdf",
    "vite",
    "plugin",
    "css"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": {
        "types": "./dist/vite.d.ts",
        "default": "./dist/vite.js"
      },
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      }
    },
    "./webpack": {
      "types": "./dist/webpack.d.ts",
      "import": {
        "types": "./dist/webpack.d.ts",
        "default": "./dist/webpack.js"
      },
      "require": {
        "types": "./dist/webpack.d.cts",
        "default": "./dist/webpack.cjs"
      }
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "import": {
        "types": "./dist/runtime.d.ts",
        "default": "./dist/runtime.js"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./preset.css": "./preset.css",
    "./preset": "./preset.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "preset.css",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@imprint-pdf/core": "workspace:*"
  },
  "peerDependencies": {
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0 || ^4.0.0",
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0",
    "webpack": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": false
    },
    "postcss": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/webpack": "^5.28.5",
    "tailwindcss": "^4.0.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "^6.4.3",
    "vitest": "catalog:",
    "webpack": "^5.107.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
