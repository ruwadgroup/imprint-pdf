{
  "name": "@imprint-pdf/cli",
  "version": "1.0.0",
  "description": "CLI for imprint-pdf: render, dev preview server, and PDF/X + PDF/UA validation.",
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint-pdf.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/tamimbinhakim/imprint-pdf/tree/main/packages/cli#readme",
  "bugs": "https://github.com/tamimbinhakim/imprint-pdf/issues",
  "keywords": [
    "pdf",
    "cli",
    "render",
    "imprint"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "imprint": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@imprint-pdf/core": "workspace:*",
    "@imprint-pdf/react": "workspace:*",
    "cac": "catalog:",
    "chokidar": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
