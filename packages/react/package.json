{
  "name": "@imprint-pdf/react",
  "version": "0.1.0",
  "description": "React components and reconciler for Imprint — Document, Page, View, Text, Image, Svg, Form, and chart adapters.",
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint-pdf.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/tamimbinhakim/imprint-pdf/tree/main/packages/react#readme",
  "bugs": "https://github.com/tamimbinhakim/imprint-pdf/issues",
  "keywords": [
    "pdf",
    "react",
    "tailwind",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./standalone": {
      "types": "./dist/standalone.d.ts",
      "import": {
        "types": "./dist/standalone.d.ts",
        "default": "./dist/standalone.js"
      },
      "require": {
        "types": "./dist/standalone.d.cts",
        "default": "./dist/standalone.cjs"
      }
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": {
        "types": "./dist/server.d.ts",
        "default": "./dist/server.js"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@imprint-pdf/core": "workspace:*",
    "react-reconciler": "catalog:"
  },
  "peerDependencies": {
    "@imprint-pdf/tailwind": "workspace:*",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@imprint-pdf/tailwind": {
      "optional": true
    }
  },
  "devDependencies": {
    "@imprint-pdf/tailwind": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-reconciler": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
