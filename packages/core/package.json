{
  "name": "@imprint-pdf/core",
  "version": "1.0.0-alpha.10",
  "description": "Framework-free PDF IR types, layout primitives, asset resolution, and Tailwind CSS processing for imprint-pdf.",
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint-pdf.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/tamimbinhakim/imprint-pdf/tree/main/packages/core#readme",
  "bugs": "https://github.com/tamimbinhakim/imprint-pdf/issues",
  "keywords": [
    "pdf",
    "react",
    "tailwind",
    "typescript",
    "wasm",
    "edge"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser.js",
      "edge-light": "./dist/browser.js",
      "workerd": "./dist/browser.js",
      "worker": "./dist/browser.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js",
      "require": "./dist/browser.cjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./assets": {
      "types": "./dist/assets.d.ts",
      "import": "./dist/assets.js",
      "require": "./dist/assets.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:ci": "vitest run --coverage",
    "bench": "vitest bench --run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "catalog:",
    "pdf-lib": "catalog:",
    "fontkit": "catalog:",
    "@pdf-lib/fontkit": "catalog:",
    "harfbuzzjs": "1.4.0",
    "taffy-wasm": "^0.9.10"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
