{
  "name": "@imprint/ua",
  "version": "0.1.0",
  "description": "Tagged PDF and PDF/UA-1 accessible output for Imprint — structure tree, alt text, language attributes, veraPDF validation.",
  "license": "BSL-1.1",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint.git",
    "directory": "packages/ua"
  },
  "homepage": "https://github.com/tamimbinhakim/imprint/tree/main/packages/ua#readme",
  "bugs": "https://github.com/tamimbinhakim/imprint/issues",
  "keywords": ["pdf-ua", "accessibility", "tagged-pdf", "ada", "eaa", "imprint"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "CHANGELOG.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ci": "vitest run --coverage",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@imprint/core": "workspace:*",
    "@imprint/react": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": { "node": ">=20.0.0" },
  "publishConfig": { "access": "public", "provenance": true }
}
