{
  "name": "@imprint-pdf/example-cloudflare-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "imprint-pdf example - Cloudflare Worker that renders a fixture invoice to PDF on the edge using the standalone WASM build.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "bench": "tsx scripts/bench.ts",
    "bench:verify": "tsx scripts/bench.ts --cold-runs 5 --max-cold-ms 100 --out bench-results.json"
  },
  "dependencies": {
    "@imprint-pdf/react": "workspace:*",
    "@imprint-pdf/fixtures": "workspace:*",
    "react": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260701.1",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "tsx": "catalog:",
    "wrangler": "^3.0.0"
  }
}
