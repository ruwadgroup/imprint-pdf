{
  "name": "imprint",
  "version": "0.0.0",
  "private": true,
  "description": "Chromium-free, isomorphic React + Tailwind PDF library. Type-correct, standards-compliant, ships everywhere.",
  "license": "Apache-2.0",
  "author": "Tamim Bin Hakim <tamimbinhakim.work@gmail.com>",
  "homepage": "https://github.com/tamimbinhakim/imprint-pdf#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamimbinhakim/imprint-pdf.git"
  },
  "bugs": {
    "url": "https://github.com/tamimbinhakim/imprint-pdf/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:ci": "turbo run test",
    "test:visual": "turbo run test:visual",
    "test:goldens:update": "turbo run test:goldens:update",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write \"**/*.{md,yml,yaml,json}\" --ignore-path .prettierignore",
    "format:check": "biome format . && prettier --check \"**/*.{md,yml,yaml,json}\" --ignore-path .prettierignore",
    "typecheck": "turbo run typecheck",
    "wasm:build": "turbo run wasm:build",
    "bench": "pnpm --filter @imprint-pdf/bench bench",
    "bench:all": "pnpm --filter @imprint-pdf/bench bench:all",
    "bench:competitors": "pnpm --filter @imprint-pdf/bench bench:competitors",
    "bench:complexity": "pnpm --filter @imprint-pdf/bench bench:complexity",
    "bench:pipeline": "pnpm --filter @imprint-pdf/bench bench:pipeline",
    "bench:features": "pnpm --filter @imprint-pdf/bench bench:features",
    "bench:chromium": "pnpm --filter @imprint-pdf/bench bench:chromium",
    "verapdf:fixtures": "pnpm --filter @imprint-pdf/print generate:fixtures",
    "verapdf:ci": "bash scripts/verapdf.sh",
    "clean": "turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build --filter=./packages/* && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@react-pdf/renderer": "^4.5.1",
    "@types/node": "^20.19.41",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2",
    "puppeteer": "^24.43.1",
    "turbo": "^2.9.14",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "*.{md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
